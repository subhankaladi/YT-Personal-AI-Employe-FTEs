# Odoo environment variables
# Copy this to .env and customize

# Database Configuration
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# Odoo Configuration
ODOO_ADMIN_PASSWORD=admin
ODOO_DB_HOST=db
ODOO_DB_PORT=5432
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=odoo

# External API Configuration
ODOO_EXTERNAL_API_URL=http://localhost:8069
ODOO_EXTERNAL_API_KEY=gold-tier-api-key-2026

# For Production (uncomment and customize):
# ODOO_EXTERNAL_API_URL=https://your-domain.com
# ODOO_EXTERNAL_API_KEY=<generate-secure-random-key>
