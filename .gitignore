# -----------------------------------------------------------------------------
# Obsidian Vault - Personal Data
# -----------------------------------------------------------------------------
AI_Employee_Vault/.obsidian/

# Keep folder structure but ignore sensitive file content
# These folders show the agent workflow for hackathon demo
AI_Employee_Vault/Logs/*.log
AI_Employee_Vault/Logs/*.txt
AI_Employee_Vault/Inbox/*.md
AI_Employee_Vault/Needs_Action/*.md
AI_Employee_Vault/In_Progress/*.md
AI_Employee_Vault/Pending_Approval/*.md
AI_Employee_Vault/Approved/*.md
AI_Employee_Vault/Rejected/*.md
AI_Employee_Vault/Done/*.md
AI_Employee_Vault/Accounting/*.md
AI_Employee_Vault/Invoices/*.md
AI_Employee_Vault/Briefings/*.md

# Keep folder structure with .gitkeep files
# AI_Employee_Vault/Logs/.gitkeep
# AI_Employee_Vault/Inbox/.gitkeep
# etc.

